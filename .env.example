# Environment variable template
#
# How to use:
#   - Never commit .env or .env.*.local — they're gitignored.
#   - .env.development / .env.staging / .env.production are committed with placeholder tokens.
#   - Override values locally by creating .env.[mode].local (also gitignored).
#
# npm scripts (see package.json):
#   npm run dev                  → dev mode (loads .env.dev)
#   npm run dev:stage            → local server → stage API (loads .env.stage)
#   npm run dev:stage2           → local server → stage2 API (loads .env.stage2)
#   npm run dev:prod             → local server → prod API (loads .env.production)
#   npm run build:stage          → build for stage deployment
#   npm run build:stage2         → build for stage2 deployment
#   npm run build:production     → build for T4 CMS production upload

# Drupal JSON:API base URL
DEV_DRUPAL_ENDPOINT=https://babsondev.prod.acquia-sites.com/jsonapi/

# Searchstax search endpoint and token
DEV_SEARCHSTAX_ENDPOINT=https://searchcloud-18-us-east-1.searchstax.com/29847/babsonbricksdatadev-7987/emselect
DEV_SEARCHSTAX_TOKEN=your-token-here

# Image URLs (hosted on Drupal)
DEV_HERO_IMAGE=https://babsondev.prod.acquia-sites.com/sites/default/files/2026-03/find-my-brick-hero.jpg
DEV_PLACEHOLDER_IMAGE=https://babsondev.prod.acquia-sites.com/sites/default/files/2026-03/coming-soon-gray.jpg
